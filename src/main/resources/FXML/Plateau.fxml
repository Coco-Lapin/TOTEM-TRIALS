<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.totemtrials.totemtrials.plateau.BoardGameController">
    <children>
        <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <!-- ═══════════════════════════════════════════════
                 TOP BAR
            ════════════════════════════════════════════════ -->
            <top>
                <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="12"
                      style="-fx-background-color: linear-gradient(to bottom, #2d1800, #1a0e00); -fx-border-color: #5c3a00; -fx-border-width: 0 0 2 0;"
                      BorderPane.alignment="CENTER">
                    <padding><Insets left="12" right="12" top="6" bottom="6"/></padding>

                    <!-- Title image (horizontal version) -->
                    <ImageView fitWidth="420" preserveRatio="true">
                        <Image url="@/images/TitreLong.png"/>
                    </ImageView>

                    <!-- Push round button to the right -->
                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- Round button: image background + number label -->
                    <StackPane alignment="CENTER" prefHeight="64" prefWidth="280">
                        <ImageView fitWidth="270" preserveRatio="true" StackPane.alignment="CENTER">
                            <Image url="@/images/buttons/bouton-round.png"/>
                        </ImageView>
                        <!-- translateX pousse le chiffre dans la zone vide à droite du mot ROUND -->
                        <Label fx:id="labelRound" text="1" translateX="95"
                               style="-fx-font-family: Impact; -fx-font-size: 26; -fx-text-fill: #ffe97a; -fx-effect: dropshadow(gaussian, black, 4, 1, 0, 0);"/>
                    </StackPane>
                </HBox>
            </top>

            <!-- ═══════════════════════════════════════════════
                 RIGHT SIDEBAR
            ════════════════════════════════════════════════ -->
            <right>
                <VBox fx:id="PlateauInfoLeft" prefWidth="210.0" spacing="10"
                      style="-fx-background-color: linear-gradient(to bottom, #2d1800, #1a0b00); -fx-border-color: #5c3a00; -fx-border-width: 0 0 0 2;">
                    <padding><Insets top="14" right="10" bottom="14" left="10"/></padding>
                    <children>

                        <!-- ── Abilities button ────────────────── -->
                        <Button fx:id="btnDetailsItem" mnemonicParsing="false" onAction="#infoItem"
                                maxWidth="Infinity"
                                style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0; -fx-cursor: hand;">
                            <graphic>
                                <ImageView fitWidth="190" preserveRatio="true">
                                    <Image url="@/images/buttons/bouton-abilities.png"/>
                                </ImageView>
                            </graphic>
                        </Button>

                        <!-- ── Ability description ─────────────── -->
                        <VBox style="-fx-background-color: rgba(0,0,0,0.45); -fx-border-color: #5c3a00; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8;">
                            <Label fx:id="ItemDescription" text="..." wrapText="true" prefWidth="170"
                                   style="-fx-font-family: Impact; -fx-font-size: 11; -fx-text-fill: #bbbbbb;"/>
                        </VBox>

                        <!-- ── Push buttons to bottom ──────────── -->
                        <Region VBox.vgrow="ALWAYS"/>

                        <!-- ── Separator ───────────────────────── -->
                        <Region prefHeight="2"
                                style="-fx-background-color: linear-gradient(to right, transparent, #5c3a00, transparent);"/>

                        <!-- ── Settings button ────────────────── -->
                        <Button fx:id="btnSettings" mnemonicParsing="false" onAction="#OpenSettings"
                                maxWidth="Infinity"
                                style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0; -fx-cursor: hand;">
                            <graphic>
                                <ImageView fitWidth="190" preserveRatio="true">
                                    <Image url="@/images/buttons/bouton-settings.png"/>
                                </ImageView>
                            </graphic>
                        </Button>

                        <!-- ── Stop / Back button ─────────────── -->
                        <Button fx:id="btnStopGame" mnemonicParsing="false" onAction="#StopGame"
                                maxWidth="Infinity"
                                style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0; -fx-cursor: hand;">
                            <graphic>
                                <ImageView fitWidth="190" preserveRatio="true">
                                    <Image url="@/images/buttons/bouton-back.png"/>
                                </ImageView>
                            </graphic>
                        </Button>

                    </children>
                </VBox>
            </right>

